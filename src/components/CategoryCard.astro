---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
  count: number;
  slug: string;
}

const { icon, title, description, href, count, slug } = Astro.props;

const gradientMap: Record<string, { from: string; to: string; glow: string }> = {
  'learning-path': { from: '#3B82F6', to: '#8B5CF6', glow: 'rgba(99,102,241,0.15)' },
  'prerequisites': { from: '#06B6D4', to: '#3B82F6', glow: 'rgba(6,182,212,0.15)' },
  'cuda-optimization': { from: '#F59E0B', to: '#EF4444', glow: 'rgba(245,158,11,0.15)' },
  'distributed-training': { from: '#10B981', to: '#06B6D4', glow: 'rgba(16,185,129,0.15)' },
  'inference-optimization': { from: '#8B5CF6', to: '#EC4899', glow: 'rgba(139,92,246,0.15)' },
  'performance-analysis': { from: '#F97316', to: '#F59E0B', glow: 'rgba(249,115,22,0.15)' },
};

const gradient = gradientMap[slug] || gradientMap['learning-path'];
---

<a
  href={href}
  class="group relative block p-6 rounded-2xl cursor-pointer transition-all duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] bg-white dark:bg-white/[0.03] border border-gray-200 dark:border-white/[0.06] hover:border-gray-300 dark:hover:border-white/[0.12] hover:shadow-xl hover:-translate-y-1"
  style={`--card-from: ${gradient.from}; --card-to: ${gradient.to}; --card-glow: ${gradient.glow};`}
>
  <!-- Gradient glow on hover -->
  <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style={`background: radial-gradient(ellipse at 50% 0%, ${gradient.glow}, transparent 70%);`}></div>

  <!-- Top accent line -->
  <div class="absolute top-0 left-6 right-6 h-[2px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300" style={`background: linear-gradient(90deg, ${gradient.from}, ${gradient.to});`}></div>

  <div class="relative z-10">
    <!-- Icon with gradient background -->
    <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4 transition-transform duration-300 group-hover:scale-110" style={`background: linear-gradient(135deg, ${gradient.from}20, ${gradient.to}20);`}>
      <svg class="w-5 h-5" style={`color: ${gradient.from};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        {slug === 'learning-path' && (
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
        )}
        {slug === 'prerequisites' && (
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
        )}
        {slug === 'cuda-optimization' && (
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z" />
        )}
        {slug === 'distributed-training' && (
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
        )}
        {slug === 'inference-optimization' && (
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
        )}
        {slug === 'performance-analysis' && (
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
        )}
      </svg>
    </div>

    <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-1.5 transition-colors duration-200 group-hover:text-transparent group-hover:bg-clip-text" style={`--tw-gradient-from: ${gradient.from}; --tw-gradient-to: ${gradient.to};`}>
      <span class="group-hover:hidden">{title}</span>
      <span class="hidden group-hover:inline bg-gradient-to-r bg-clip-text text-transparent" style={`background-image: linear-gradient(to right, ${gradient.from}, ${gradient.to});`}>{title}</span>
    </h3>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 line-clamp-2 leading-relaxed">
      {description}
    </p>

    <!-- Footer -->
    <div class="flex items-center justify-between">
      <span class="text-xs font-medium text-gray-400 dark:text-gray-500">
        {count} 篇文章
      </span>
      <span class="flex items-center gap-1 text-xs font-medium opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-[-4px] group-hover:translate-x-0" style={`color: ${gradient.from};`}>
        探索
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </span>
    </div>
  </div>
</a>
