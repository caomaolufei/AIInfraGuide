---
import { getCollection } from 'astro:content';
import { GUIDE_CATEGORIES, type CategorySlug } from '../utils/categories';

const guides = await getCollection('guides', ({ data }) => !data.draft);
const currentPath = Astro.url.pathname;

const grouped = Object.entries(GUIDE_CATEGORIES)
  .map(([slug, meta]) => ({
    slug: slug as CategorySlug,
    ...meta,
    items: guides
      .filter((g) => g.data.category === slug)
      .sort((a, b) => a.data.order - b.data.order),
  }))
  .filter((group) => group.items.length > 0);

const getGuidePath = (guideSlug: string) => {
  const base = import.meta.env.BASE_URL;
  const path = `/guides/${guideSlug}`;
  return base === '/' ? path : `${base.replace(/\/$/, '')}${path}`;
};
---

<nav class="w-64 shrink-0 sticky top-24 h-[calc(100vh-8rem)] overflow-y-auto sidebar-scroll pr-4">
  <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">
    知识库导航
  </h3>
  <div class="space-y-6">
    {grouped.map((group) => (
      <div>
        <div class="flex items-center gap-2 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">
          <span>{group.icon}</span>
          <span>{group.label}</span>
        </div>
        <ul class="space-y-1">
          {group.items.map((item) => {
            const href = getGuidePath(item.slug);
            const isActive = currentPath.includes(item.slug);
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'block px-3 py-1.5 rounded-lg text-sm transition-all duration-200',
                    isActive
                      ? 'text-[#007aff] dark:text-[#0a84ff] bg-blue-50 dark:bg-blue-900/20 font-medium'
                      : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-white/5',
                  ]}
                >
                  {item.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>
</nav>
